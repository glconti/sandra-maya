{
  "Telegram": {
    "PollingTimeoutSeconds": 30,
    "ErrorBackoffSeconds": 5,
    "MaxUpdatesPerRequest": 25,
    "IncludeEditedMessages": true
  },
  "AzureOpenAi": {
    "ProviderType": "azure",
    "ApiVersion": "2025-04-01-preview"
  },
  "Storage": {
    "Root": "App_Data",
    "SqlitePath": "sqlite/sandra-maya.db",
    "UploadsPath": "files",
    "RuntimeSkillsPath": "Assistant\\Skills",
    "WorkPath": "work",
    "TempPath": "tmp"
  },
  "Runtime": {
    "PlaywrightCommand": "node"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
