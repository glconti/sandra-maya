{
  "Telegram": {
    "PollingTimeoutSeconds": 30,
    "ErrorBackoffSeconds": 5,
    "MaxUpdatesPerRequest": 25,
    "IncludeEditedMessages": true
  },
  "AzureOpenAi": {
    "ProviderType": "azure",
    "ApiVersion": "2024-10-21"
  },
  "Storage": {
    "Root": "App_Data",
    "CapabilityRegistryFileName": "capability-registry.json"
  },
  "Runtime": {
    "DotNetCommand": "dotnet",
    "NodeCommand": "node",
    "PlaywrightCommand": "node",
    "PythonCommand": "python",
    "PowerShellCommand": "pwsh",
    "BashCommand": "bash"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
