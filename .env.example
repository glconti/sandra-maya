# Build-time settings (Coolify build args or local docker build --build-arg)
PROJECT_PATH=src/SandraMaya.Host/SandraMaya.Host.csproj
INSTALL_PLAYWRIGHT_BROWSERS=false

# Runtime bootstrapping
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
APP_DLL=
APP_PROJECT_NAME=SandraMaya.Host

# Telegram bot
Telegram__BotToken=
Telegram__PollingTimeoutSeconds=30
Telegram__ErrorBackoffSeconds=5
Telegram__MaxUpdatesPerRequest=25
Telegram__IncludeEditedMessages=true

# Azure OpenAI / Azure AI Foundry
AzureOpenAi__ProviderType=azure
AzureOpenAi__BaseUrl=https://your-resource.openai.azure.com
AzureOpenAi__ApiKey=
AzureOpenAi__DeploymentName=your-deployment-name
AzureOpenAi__ApiVersion=2024-10-21
AzureOpenAi__WireApi=

# Persistent storage mounted from Coolify
Storage__Root=/data
Storage__SqlitePath=sqlite/sandra-maya.db
Storage__UploadsPath=files
Storage__CapabilitiesPath=capabilities
Storage__GeneratedCapabilitiesPath=capabilities/generated
Storage__WorkPath=work
Storage__TempPath=tmp
Storage__CapabilityRegistryFileName=capability-registry.json

# Capability runtime command overrides
Runtime__DotNetCommand=dotnet
Runtime__NodeCommand=node
Runtime__PlaywrightCommand=node
Runtime__PythonCommand=python
Runtime__PowerShellCommand=pwsh
Runtime__BashCommand=bash

# Multi-runtime container dependencies
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# Coolify notes:
# 1. Mount a persistent volume at /data.
# 2. Set PROJECT_PATH to the runnable .csproj for the bot/web host.
# 3. Expose port 8080 only if the app serves HTTP or health endpoints.
# 4. Set INSTALL_PLAYWRIGHT_BROWSERS=true only when browser automation is required.

